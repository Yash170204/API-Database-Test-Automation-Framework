# Environment settings
TEST_ENV=local

# API target configuration
# (Note: In tests, the server port will be dynamically determined, but for external manual runs this defaults to 8000)
BASE_URL=http://127.0.0.1:8000
REQUEST_TIMEOUT=5

# Database configuration
# (Can be a path to SQLite or database connection string)
DATABASE_PATH=inventory.db

# Logging
LOG_LEVEL=INFO
